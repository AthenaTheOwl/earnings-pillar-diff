{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/earnings-pillar-diff/memo.schema.json",
  "title": "Earnings Pillar Diff memo frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ticker",
    "quarter",
    "filing_url",
    "filing_date",
    "pillars_affected",
    "action",
    "revert_threshold"
  ],
  "properties": {
    "ticker": {
      "type": "string",
      "enum": ["MSFT", "GOOG", "AMZN", "META", "ORCL"]
    },
    "quarter": {
      "type": "string",
      "pattern": "^[0-9]{4}Q[1-4]$"
    },
    "filing_url": {
      "type": "string",
      "pattern": "^https://www\\.sec\\.gov/"
    },
    "filing_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}(T[0-9]{2}:[0-9]{2}:[0-9]{2}Z)?$"
    },
    "pillars_affected": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
      },
      "uniqueItems": true
    },
    "action": {
      "type": "string",
      "enum": ["HOLD", "TRIM", "ADD", "HEDGE"]
    },
    "revert_threshold": {
      "type": "string",
      "minLength": 12
    }
  }
}
